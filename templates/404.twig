{% extends "_layouts/default" %}

{% block content %}
    <div class="container mx-auto px-4 py-24 lg:py-32 text-center">
        <div class="max-w-2xl mx-auto">
            <h1 class="text-6xl lg:text-8xl font-bold text-gray-900 mb-6">404</h1>
            <h2 class="text-2xl lg:text-3xl font-semibold text-gray-800 mb-4">Seite nicht gefunden</h2>
            <p class="text-lg text-gray-600 mb-8">
                Die gesuchte Seite existiert leider nicht (mehr).
                Vielleicht finden Sie auf unserer Startseite, was Sie suchen.
            </p>
            <a href="{{ siteUrl }}"
               class="group relative inline-block bg-brand-primary hover:bg-brand-secondary text-white px-8 py-4 rounded-full hover:scale-105 hover:shadow-xl active:scale-95 transition-all duration-200 font-semibold">
                <span class="relative z-10 inline-block mr-2 group-hover:-translate-x-1 transition-transform duration-200">←</span>
                <span class="relative z-10">Zur Startseite</span>
            </a>
        </div>
    </div>
{% endblock %}
