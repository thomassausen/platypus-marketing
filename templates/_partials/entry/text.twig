{# Text Section Component #}

{% import '_partials/theme-macros.twig' as theme %}
{% import '_partials/ui-macros.twig' as ui %}

{% set background = entry.backgroundColor.value ?? entry.backgroundColor ?? 'transparent' %}
{% set layout = entry.textLayout ?? 'one-column' %}
{% set svgVariant = entry.svgVariant ?? 1 %}
{% set containerWidth = entry.containerWidth.value ?? entry.containerWidth ?? 'default' %}
{% set vars = theme.getThemeVars(background)|json_decode %}

{# Map containerWidth to Tailwind classes #}
{% if containerWidth == 'narrow' %}
    {% set containerClass = 'max-w-5xl' %}
{% elseif containerWidth == 'wide' %}
    {% set containerClass = 'max-w-[1920px]' %}
{% elseif containerWidth == 'full' %}
    {% set containerClass = 'max-w-full' %}
{% else %}
    {% set containerClass = 'max-w-7xl' %}
{% endif %}

<section class="py-20 lg:py-28 relative {{ vars.backgroundClass }}">
    {# SVG Background Shapes #}
    {{ ui.svgShapes(svgVariant, vars) }}

    <div class="{{ containerClass }} mx-auto px-4 lg:px-8 relative z-10">
        {% if layout == 'one-column' %}
            {# One Column Layout #}
            <div class="max-w-4xl">
                {% include '_partials/text-content.twig' with {
                    subtitle: entry.subtitle,
                    title: entry.title,
                    description: entry.description,
                    text: entry.text,
                    button: entry.button,
                    subtitleBgClass: vars.subtitleBgClass,
                    titleColorClass: vars.titleColorClass,
                    textColorClass: vars.textColorClass,
                    buttonClass: vars.buttonClass,
                    buttonTextClass: vars.buttonTextClass,
                    buttonAlign: ''
                } %}
            </div>
        {% else %}
            {# Two Column Layout #}
            <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
                {# Sticky Header Column #}
                <div class="lg:sticky lg:top-24">
                    {{ ui.subtitle(entry.subtitle, vars.subtitleBgClass) }}
                    <h2 class="text-3xl lg:text-5xl font-bold {{ vars.titleColorClass }} leading-tight">{{ entry.title }}</h2>
                </div>

                {# Content Column #}
                <div>
                    {% if entry.description %}
                        <div class="text-xl lg:text-2xl {{ vars.textColorClass }} mb-8 content-styles font-bold leading-relaxed">{{ entry.description }}</div>
                    {% endif %}
                    {% if entry.text %}
                        <div class="text-lg lg:text-xl {{ vars.textColorClass }} mb-8 space-y-4 content-styles leading-relaxed">
                            {{ entry.text }}
                        </div>
                    {% endif %}
                    {{ ui.buttonPrimary(entry.button, vars.buttonClass, vars.buttonTextClass) }}
                </div>
            </div>
        {% endif %}
    </div>
</section>
