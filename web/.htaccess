# BEGIN Hoster
AddType application/x-httpd-php83 .php
# END Hoster

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 301 Redirects for old project URLs
    RewriteRule ^projekte/docatwork/?$ /was-wir-tun [R=301,L]
    RewriteRule ^projekte/?$ /was-wir-tun [R=301,L]
    RewriteRule ^projekte/promotion-pool/?$ /was-wir-tun [R=301,L]
    RewriteRule ^projekte/hamburg-marketing/?$ /was-wir-tun [R=301,L]

    # Route 404s to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/(favicon\.ico|apple-touch-icon.*\.png)$ [NC]
    RewriteRule (.+) index.php [L]
</IfModule>
